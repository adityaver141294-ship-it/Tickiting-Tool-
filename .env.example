# ==============================================================
# TicketFlow — Environment Variables
# ==============================================================
# 1. Copy this file:   cp .env.example .env
# 2. Fill in values below (NEVER commit .env to git!)
# ==============================================================

# Server
NODE_ENV=production
PORT=3000

# Database
DB_PATH=/data/database.sqlite
INITIAL_ADMIN_PASSWORD=your_strong_admin_password_here
JWT_SECRET=your_strong_random_jwt_secret_key_here

# CORS — comma-separated list of allowed frontend origins
# Example: https://tickets.yourcompany.com,http://localhost:8080
ALLOWED_ORIGINS=http://localhost:8080
